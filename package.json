{
  "name": "weatherguard-admin",
  "version": "1.0.0",
  "description": "Secure, invite-only weather alert service with admin dashboard and Telegram bot integration",
  "private": true,
  "scripts": {
    "setup": "bash setup.sh",
    "setup:windows": "setup.bat",
    "dev:api": "cd api && npm run dev",
    "dev:admin": "cd admin && npm run dev",
    "build": "npm run build:api && npm run build:admin",
    "build:api": "cd api && npm run build",
    "build:admin": "cd admin && npm run build",
    "start": "npm run start:api",
    "start:api": "cd api && npm run start:prod",
    "docker:dev": "docker-compose up -d",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:down": "docker-compose down",
    "test": "npm run test:api",
    "test:api": "cd api && npm run test"
  },
  "keywords": [
    "weather",
    "alerts",
    "telegram",
    "bot",
    "admin",
    "dashboard",
    "nestjs",
    "react",
    "mongodb"
  ],
  "author": "AI47 Labs Assessment",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@types/js-cookie": "^3.0.6",
    "autoprefixer": "^10.5.2",
    "axios": "^1.18.1",
    "js-cookie": "^3.0.8",
    "postcss": "^8.5.15",
    "react-router-dom": "^7.18.0",
    "tailwindcss": "^4.3.1",
    "zustand": "^5.0.14"
  }
}
